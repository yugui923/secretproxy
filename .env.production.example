# Secret Proxy — production environment variables
#
# Copy to your platform's secret store. Never commit real values to git.
# Reference: docs/specs/2026-05-08-secret-proxy.md §4.1 (Server Configuration).

# ─── Required ────────────────────────────────────────────────────────────────

# Curve25519 private key. Prefer the FILE form in production — env vars are
# visible in /proc/<pid>/environ and crash dumps.
SECRET_PROXY_PRIVATE_KEY_FILE=/secrets/private.hex
# SECRET_PROXY_PRIVATE_KEY=                  # inline fallback (PaaS-only)

# TLS material for the HTTPS-only listener. Skip both vars when running
# behind a platform TLS terminator (Render, Cloud Run, Heroku, App Runner);
# in that case set SECRET_PROXY_TRUST_TLS_TERMINATOR=1 below instead.
SECRET_PROXY_TLS_CERT_FILE=/secrets/cert.pem
SECRET_PROXY_TLS_KEY_FILE=/secrets/key.pem

# Behind-terminator mode (mutually exclusive with the TLS files above).
# See spec §3.2 and §5.1 footgun #4 — only safe when the proxy port is
# unreachable except via the upstream TLS terminator.
# SECRET_PROXY_TRUST_TLS_TERMINATOR=1

# ─── Operational ─────────────────────────────────────────────────────────────

# Bind address. Set to ":$PORT" on platforms that inject a port.
SECRET_PROXY_LISTEN_ADDRESS=:8443

# Logging.
SECRET_PROXY_LOG_LEVEL=info

# Strip platform-injected trust-anchor headers so clients can't spoof identity.
# Adjust per platform (k8s ingress, mesh, PaaS edge LB).
SECRET_PROXY_FILTERED_HEADERS=X-Forwarded-For,X-Real-IP,X-Forwarded-Proto

# Self-loop guard. Add every public hostname this proxy is reachable under.
# 'localhost', loopback IPs, and os.Hostname() are auto-added.
SECRET_PROXY_SELF_HOSTNAMES=secret-proxy.example.com

# Ingress IP allowlist on /v1/forward. Comma-separated CIDR or bare IPs
# (bare IPs become /32 or /128). Empty/unset = off (default). When behind
# a TLS terminator (SECRET_PROXY_TRUST_TLS_TERMINATOR=1) the proxy reads
# the rightmost X-Forwarded-For entry — list your client apps' public
# egress IPs. See spec §5.1 footgun #9.
# SECRET_PROXY_ALLOWED_CLIENT_CIDRS=203.0.113.0/24,198.51.100.7

# ─── Optional: zero-downtime key rotation ────────────────────────────────────

# Set during a rotation window; remove after re-sealing all client secrets.
# SECRET_PROXY_PREVIOUS_PRIVATE_KEY_FILE=/secrets/previous.hex
# SECRET_PROXY_PREVIOUS_PRIVATE_KEY=                # PaaS-only inline form

# ─── DO NOT SET IN PRODUCTION ────────────────────────────────────────────────

# SECRET_PROXY_ALLOW_NO_AUTH=                # permits no_auth seals
# SECRET_PROXY_ALLOW_PASSTHROUGH=            # forwards requests with no seal
